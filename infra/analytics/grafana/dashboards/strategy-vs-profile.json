          "rawSql": "SELECT\n  concat(strategy_id, ' / ', profile_id) AS `Stratégie / profil`,\n  sum(costs_usdc) AS `Coûts`,\n  sum(gross_pnl_usdc) AS `PnL brut`,\n  sum(net_pnl_usdc) AS `PnL net`\nFROM prediction_core.paper_pnl_snapshots\nWHERE $__timeFilter(observed_at)\n  AND match(strategy_id, '${strategy:regex}')\n  AND match(profile_id, '${profile:regex}')\n  AND match(mode, '${mode:regex}')\nGROUP BY `Stratégie / profil`\nORDER BY `Coûts` DESC",
          "refId": "A"
        }
      ],
      "title": "Coûts",
      "type": "barchart"
    }
  ],
