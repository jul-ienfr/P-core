          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT\n  strategy_id AS `Stratégie`,\n  profile_id AS `Profil`,\n  sum(decision_count) AS `Décisions`,\n  sum(trade_count) AS `Trades`,\n  sum(skip_count) AS `Skips`,\n  sum(skip_count) / nullIf(sum(decision_count), 0) AS `Taux de skip`,\n  sum(net_pnl_usdc) AS `PnL net`,\n  avg(roi) AS `ROI moyen`,\n  anyLast(exposure_usdc) AS `Exposition récente`\nFROM prediction_core.profile_metrics\nWHERE $__timeFilter(observed_at)\n  AND match(strategy_id, '${strategy:regex}')\n  AND match(profile_id, '${profile:regex}')\n  AND match(mode, '${mode:regex}')\nGROUP BY strategy_id, profile_id\nORDER BY `PnL net` DESC",
