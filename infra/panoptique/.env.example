# Panoptique local development defaults only.
# Do not put production secrets or wallet credentials in this file.

PANOPTIQUE_POSTGRES_DB=panoptique
PANOPTIQUE_POSTGRES_USER=panoptique
PANOPTIQUE_POSTGRES_PASSWORD=panoptique
PANOPTIQUE_POSTGRES_PORT=5432
PANOPTIQUE_REDIS_PORT=6379

PANOPTIQUE_DATABASE_URL=postgresql+asyncpg://panoptique:panoptique@localhost:5432/panoptique
PANOPTIQUE_SYNC_DATABASE_URL=postgresql+psycopg://panoptique:panoptique@localhost:5432/panoptique
PANOPTIQUE_REDIS_URL=redis://localhost:6379/0
